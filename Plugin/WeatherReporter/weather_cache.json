  "warning": [
    {
      "id": "10128010920260724082400286159413",
      "sender": "广州市气象台",
      "pubTime": "2026-07-24T08:24+08:00",
      "title": "广州市气象台发布台风白色预警",
      "startTime": "2026-07-24T08:24+08:00",
      "endTime": "2026-07-25T08:24+08:00",
      "status": "active",
      "level": "白色",
      "severity": "Unknown",
      "severityColor": "Gray",
      "type": "1001",
      "typeName": "台风",
      "urgency": "",
      "certainty": "",
      "text": "广州市气象台24日08时24分发布台风白色预警信号:菲律宾以东的热带低压今天（24日）凌晨加强为今年第12号台风“红霞”（热带风暴级），早晨5时其中心位于广州东南方向约1300公里的洋面上。预计其将以每小时25-30公里的速度向西偏北方向移动，未来48小时内将对广州有影响。从24日08时24分起，广州市越秀区、天河区台风白色预警信号生效，请提前做好防御工作。广州市气象台07月24日08时24分发布。",
      "related": ""
    },
    {
      "id": "10128010920260723165100072211816",
      "sender": "广东省三防办，气象局",
      "pubTime": "2026-07-23T16:51+08:00",
      "title": "台风防御提醒",
      "startTime": "2026-07-23T16:51+08:00",
      "endTime": "2026-07-24T17:06+08:00",
      "status": "active",
      "level": "白色",
      "severity": "Unknown",
      "severityColor": "Gray",
      "type": "9999",
      "typeName": "其他预警",
      "urgency": "",
      "certainty": "",
      "text": "广东省三防办、气象局提醒您：热带低压已生成，将发展为今年第12号台风“红霞”，并正面袭击我省。预计25日夜间-26日，我省中东部市县有暴雨局部特大暴雨和7-10级阵风；24日夜间-26日，我省中东部海面、南海东北部海面风力7-11级；台风中心经过的附近海面和市县风力12-14级。请密切关注台风动向，及时做好防御。（省预警中心7月23日发布）",
      "related": ""
    }
  ],
